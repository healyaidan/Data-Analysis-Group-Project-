library(tidyverse)
library(kableExtra)
library(ggplot2)
dat1 <- dat %>%
mutate(prop = Y/N, after = ifelse(Year>=2004,1,0))
dat2 <- dat %>%
mutate(prop = Y/N, after = ifelse(Year>=2008,1,0))
dat$Year <- (dat$Year - 2004)/2
dat1$Year <- as.factor(dat1$Year)
dat2$Year <- as.factor(dat2$Year)
dat1$after <- as.factor(dat1$after)
dat2$after <- as.factor(dat2$after)
model1 <- glm(cbind(Y,N-Y) ~ Year + after, family = binomial, dat1)
model2 <- glm(cbind(Y,N-Y) ~ Year + after, family = binomial, dat2)
summary(model1)
summary(model2)
model1 <- glm(cbind(Y,N-Y) ~ Year + after + Year*after, family = binomial, dat1)
model2 <- glm(cbind(Y,N-Y) ~ Year + after + Year*after, family = binomial, dat2)
summary(model1)
summary(model2)
